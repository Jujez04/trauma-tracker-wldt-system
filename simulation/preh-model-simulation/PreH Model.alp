					</Points>
					<IconOffset>20.0</IconOffset>
					<Properties Source="1776441234563" Target="1776441234565" Trigger="timeout">
						<Action><![CDATA[Hospital bestHospital = null;
double minHospDist = infinity;

for (Hospital h : main.hospitalsCollection) {
	if(h.assistanceLevel == 2) {
		double d = this.distanceTo(h);
	    if (d < minHospDist) {
	        minHospDist = d;
	        bestHospital = h;
	    }
	}
}

this.targetHospital = bestHospital;
this.moveTo(targetHospital);
traceln("Helicopter moving to " + bestHospital);]]></Action>
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[targetPatient.severityCode == SeverityCode.RED ? main.takingPatientTimeUB : main.takingPatientTimeLB]]></Code>
