					<Properties Width="130" Height="30">
						<EntryAction><![CDATA[Hospital bestHospital = null;
double minHospDist = infinity;

for (Hospital h : main.hospitalsCollection) {
    if (this.targetPatient.severityCode == SeverityCode.RED && h.assistanceLevel > 1) {
        double d = this.distanceTo(h);
	    if (d < minHospDist) {
	        minHospDist = d;
	        bestHospital = h;
	    }
    }

    
}

this.targetHospital = bestHospital;]]></EntryAction>
