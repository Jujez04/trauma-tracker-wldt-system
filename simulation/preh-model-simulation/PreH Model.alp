					</StepDurationCode>
					<SpaceType>CONTINUOUS</SpaceType>
					<WidthCode><![CDATA[500]]></WidthCode>
					<HeightCode><![CDATA[500]]></HeightCode>
					<ZHeightCode><![CDATA[0]]></ZHeightCode>
					<ColumnsCountCode><![CDATA[100]]></ColumnsCountCode>
					<RowsCountCode><![CDATA[100]]></RowsCountCode>
					<NeigborhoodType>MOORE</NeigborhoodType>
					<LayoutType>USER_DEF</LayoutType>
					<NetworkType>USER_DEF</NetworkType>
					<ConnectionsPerAgentCode><![CDATA[2]]></ConnectionsPerAgentCode>
					<ConnectionsRangeCode><![CDATA[50]]></ConnectionsRangeCode>
					<NeighborLinkFractionCode><![CDATA[0.95]]></NeighborLinkFractionCode>
					<MCode><![CDATA[10]]></MCode>
			</EnvironmentProperties>
			<DatasetsCreationProperties>
				<AutoCreate>true</AutoCreate>
					<Id>1776926640655</Id>
					<OccurrenceAtTime>true</OccurrenceAtTime>
					<OccurrenceDate>1776931200000</OccurrenceDate>
					<OccurrenceTime Class="CodeUnitValue">
						<Code><![CDATA[0]]></Code>
						<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
					</OccurrenceTime>
					<RecurrenceCode Class="CodeUnitValue">
						<Code><![CDATA[1]]></Code>
						<Unit Class="TimeUnits"><![CDATA[SECOND]]></Unit>
					</RecurrenceCode>
			</DatasetsCreationProperties>
			<ScaleRuler>
				<Id>1776926640659</Id>
				<Name><![CDATA[scale]]></Name>
				<X>0</X><Y>-150</Y>
				<PublicFlag>false</PublicFlag>
				<PresentationFlag>false</PresentationFlag>
				<ShowLabel>false</ShowLabel>
				<DrawMode>SHAPE_DRAW_2D3D</DrawMode>
				<Length>100</Length>
				<Rotation>0</Rotation>
				<ScaleType>BASED_ON_LENGTH</ScaleType>
				<ModelLength>10</ModelLength>
				<LengthUnits>METER</LengthUnits>
				<Scale>10</Scale>
				<InheritedFromParentAgentType>true</InheritedFromParentAgentType>
			</ScaleRuler>
			<CurrentLevel>1776926640662</CurrentLevel>
			<ConnectionsId>1776926640657</ConnectionsId>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1776926875413</Id>
					<Name><![CDATA[handleSignals]]></Name>
					<X>50</X><Y>40</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[Ambulance closestAmbulance = null;
MedCar closestCar = null;
double minDistance = infinity;
double minDistanceCar = infinity;

for (Ambulance a : main.ambulancesCollection) {
    boolean operative = a.isH24 || (main.dayRoutine.getValue() == 1);
    if (operative && (a.inState(Ambulance.atRest) || a.inState(Ambulance.Returning))) {
        double d = a.distanceTo(p);
        if (d < minDistance) {
            minDistance = d;
            closestAmbulance = a;
        }
    }
}

for (MedCar m : main.medCarsCollection) {
    if (m.inState(MedCar.atRest) || m.inState(MedCar.Returning)) {
        double d = m.distanceTo(p);
        if (d < minDistanceCar) {
            minDistanceCar = d;
            closestCar = m;
        }
    }
}

MedHelicopter freeHeli = findFirst(main.medHelicopters, h -> h.inState(MedHelicopter.atRest));

if (closestAmbulance == null) {
    traceln("No ambulance ready. Waiting for support");
    return; // Patient wait in Signaled state
}

send("Ambulance Call received, taking action", p);

if (p.severityCode == SeverityCode.RED) {
    if (minDistance > main.distanceThreshold && freeHeli != null) {
        p.medicalAssisted = true; 
        p.inHelicopter = true;
        
        traceln("Code: " + p.severityCode + ", Distance: (" + minDistance/1000 + "km) -> Sending Ambulance and MedHelicopter");
        send(p, freeHeli);
        send(p, closestAmbulance);
        
    } else if (closestCar != null) {
        p.medicalAssisted = false;
        p.inHelicopter = false;
        
        traceln("Code: " + p.severityCode + ", Distance: " + minDistance/1000 + "km -> Sending MedCar and Ambulance");
        send(p, closestCar);
        send(p, closestAmbulance);
        
    } else {
        p.medicalAssisted = true;
        p.inHelicopter = false;
        
        traceln("No advanced support vehicle available, sending Ambulance");
        send(p, closestAmbulance);
    }
    
} else if (p.severityCode == SeverityCode.YELLOW) {
    p.medicalAssisted = true;
    p.inHelicopter = false;
    
    traceln("Code: " + p.severityCode + " -> Sending Ambulance and nurse as support");
    send(p, closestAmbulance);
    
} else {
    p.medicalAssisted = true;
    p.inHelicopter = false;
    
    traceln("Code: " + p.severityCode + ", sending Ambulance ");
    send(p, closestAmbulance);
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Position]]></ReturnType>
					<Id>1778075578527</Id>
					<Name><![CDATA[getNearestHospitalPosition]]></Name>
					<X>50</X><Y>70</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[agent]]></Name>
						<Type><![CDATA[Agent]]></Type>
					</Parameter>
					<Body><![CDATA[Hospital closestHospital = null;
double minDistance = infinity;

for (Hospital h : main.hospitalsCollection) {
    double d = h.distanceTo(agent);
    if (d < minDistance) {
        minDistance = d;
        closestHospital = h;
    }
}


return closestHospital.getPosition();]]></Body>
				</Function>
